# ── DHIS2 ─────────────────────────────────────────────────────────────────────
DHIS2_ADMIN_USER=admin
DHIS2_ADMIN_PASS=district
DHIS2_USER_PASSWORD=your_chosen_password   # used for all 5 human demo accounts
DHIS2_BASE_URL=http://localhost:8080/api

# ── PostgreSQL (Docker Compose) ────────────────────────────────────────────────
POSTGRES_DB=dhis2
POSTGRES_USER=dhis
POSTGRES_PASSWORD=your_db_password

# ── Agent service account (created by dhis2/build_users.py) ───────────────────
AGENT_USER=agent_service
AGENT_PASS=your_chosen_password            # can match DHIS2_USER_PASSWORD for local dev

# ── Claude API ────────────────────────────────────────────────────────────────
CLAUDE_API_KEY=

# ── Twilio SMS ────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=+1xxxxxxxxxx                  # your Twilio number in E.164 format
